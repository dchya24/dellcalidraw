# Server Configuration
EXCALIDRAW_SERVER_PORT=8080
EXCALIDRAW_SERVER_READ_TIMEOUT=10s
EXCALIDRAW_SERVER_WRITE_TIMEOUT=10s
EXCALIDRAW_SERVER_IDLE_TIMEOUT=60s

# WebSocket Configuration
EXCALIDRAW_WEBSOCKET_READ_BUFFER_SIZE=1024
EXCALIDRAW_WEBSOCKET_WRITE_BUFFER_SIZE=1024
EXCALIDRAW_WEBSOCKET_PING_PERIOD=54s
EXCALIDRAW_WEBSOCKET_PONG_WAIT=60s

# Room Configuration
EXCALIDRAW_ROOM_CAPACITY=50
EXCALIDRAW_ROOM_INACTIVITY_TIMEOUT=1h
EXCALIDRAW_ROOM_CLEANUP_INTERVAL=10m

# Logging
EXCALIDRAW_LOG_LEVEL=info
EXCALIDRAW_LOG_FORMAT=json

# Storage (MinIO/S3)
EXCALIDRAW_STORAGE_ENDPOINT=localhost:9000
EXCALIDRAW_STORAGE_ACCESS_KEY=minioadmin
EXCALIDRAW_STORAGE_SECRET_KEY=minioadmin
EXCALIDRAW_STORAGE_BUCKET=excalidraw-files
EXCALIDRAW_STORAGE_REGION=us-east-1
EXCALIDRAW_STORAGE_USE_SSL=false
EXCALIDRAW_STORAGE_PUBLIC=false

# Auth (JWT)
EXCALIDRAW_AUTH_SECRET_KEY=change-me-in-production-please
EXCALIDRAW_AUTH_ACCESS_TOKEN_TTL=15m
EXCALIDRAW_AUTH_REFRESH_TOKEN_TTL=168h
